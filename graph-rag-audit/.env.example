# Next.js — copier vers .env.local et ajuster

# URL du worker FastAPI (uniquement côté serveur Next : /api/ingest et /api/ingest/status/...)
WORKER_URL=http://localhost:8000

# Optionnel : rétrocompat si tu avais déjà NEXT_PUBLIC_WORKER_URL (sinon ignoré pour le polling).
# NEXT_PUBLIC_WORKER_URL=http://localhost:8000

# NextAuth (GitHub OAuth)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=
# GITHUB_ID=
# GITHUB_SECRET=
